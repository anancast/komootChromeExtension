{
  "manifest_version": 3,
  "name": "Komoot extension",
  "description": "download user routes",
  "version": "1.1",
  "permissions": [
     "scripting"
  ],
  "host_permissions": [
     "*://*.www.komoot.com/"
   ],
   "content_scripts": [
    {
      "matches": ["*://*.www.komoot.com/*"],
      "js": ["injection.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content-script.js"],
      "matches": ["*://*.www.komoot.com/*"]
    }
  ]
}